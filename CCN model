        "    np.random.shuffle(images)\n",
        "\n",
        "    train_idx = int(len(images) * 0.7)\n",
        "    val_idx = int(len(images) * 0.9)\n",
        "\n",
        "    for i, img in enumerate(images):\n",
        "        src = os.path.join(cls_path, img)\n",
